# --- Local mode (default when Supabase URL is empty) ---
# Profiles stored in data/users.json on disk
# Session ends when you quit the browser/app
JARVIS_LOCAL_AUTH=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared-secret bearer token for external XP awards (POST /api/xp/award),
# e.g. from Janus on task completion or Mind on a routed habit capture.
# Leave unset for local dev — the endpoint allows unauthenticated requests.
FORGE_API_TOKEN=

# Required by /api/coach and /api/photos/analyze (Claude-powered features).
ANTHROPIC_API_KEY=

# --- Cloud mode (optional) ---
# Uncomment and set these to use Supabase + Google instead
# JARVIS_LOCAL_AUTH=false
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
