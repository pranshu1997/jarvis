# --- Local mode (default when Supabase URL is empty) ---
# Profiles stored in data/users.json on disk
# Session ends when you quit the browser/app
JARVIS_LOCAL_AUTH=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cloud mode (optional) ---
# Uncomment and set these to use Supabase + Google instead
# JARVIS_LOCAL_AUTH=false
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
